/* 页面容器样式 */
.container {
    padding: 20px;
    background-color: #f7f7f7;
  }
  
  /* 内容样式 */
  .content {
    background-color: #ffffff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  /* 标题样式 */
  .title {
    font-size: 20px;
    font-weight: bold;
    text-align: center;
    margin-bottom: 20px;
  }
  
  /* 每个章节的容器样式 */
  .section {
    margin-bottom: 20px;
  }
  
  /* 章节标题样式 */
  .section-title {
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 10px;
    color: #333;
  }
  
  /* 章节内容文本样式 */
  .section-text {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }
  