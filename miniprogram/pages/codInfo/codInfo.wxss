.container {
    padding: 20px;
    background-color: #D2B48C; /* 暖棕色 */
    min-height: 100vh; /* 保证背景颜色覆盖整个页面 */
  }
  
  .section {
    margin-bottom: 20px;
    text-align: left;
    line-height: 1.5;
  }
  
  .section-title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 10px;
  }
  
  .section-content {
    font-size: 16px;
    line-height: 1.5;
  }
  